# Gracey environment template
# Copy to .env on your Spark node and fill with real values.
# Do NOT commit .env with live tokens.

# Core node identity
GRACEY_NODE_HOSTNAME=promaxgb10-4afb.local
GRACEY_SYSTEM_NAME=Gracey-GB10
GRACEY_NODE_ID=gracey-gb10

# Networking
TAILSCALE_ENABLED=true
NVIDIA_SYNC_ENABLED=true

# API security
API_GATEWAY_AUTH_TOKEN=<set-strong-random-token>

# Telegram integration
TELEGRAM_ENABLED=true
TELEGRAM_BOT_USERNAME=@GraceyGB10
TELEGRAM_DISPLAY_NAME=Gracey-GB10
TELEGRAM_BOT_TOKEN=<set-existing-telegram-bot-api-key>

# Optional NVIDIA endpoint provider
NVIDIA_API_KEY=<optional-if-using-nvidia-endpoints>

# Runtime endpoint wiring
INFERENCE_ROUTER_URL=http://127.0.0.1:8080
