# ── Model weight files (large binary assets — store outside git) ──────────────
openclaw/models/**/*.safetensors
openclaw/models/**/*.bin
openclaw/models/**/*.gguf
openclaw/models/**/*.pt
openclaw/models/**/*.pth
openclaw/models/**/*.ckpt
openclaw/models/**/*.ggml
openclaw/models/**/*.q4_0
openclaw/models/**/*.q8_0
# Allow metadata / config files inside model directories
!openclaw/models/**/*.json
!openclaw/models/**/*.yaml
!openclaw/models/**/*.txt
!openclaw/models/**/README.md
!openclaw/models/**/tokenizer*

